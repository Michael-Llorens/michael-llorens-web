---
import PageLayout from '../components/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Guarantees from '../components/Guarantees.astro';
import Services from '../components/Services.astro';
import Comparison from '../components/Comparison.astro';
import ProjectsCarousel from '../components/ProjectsCarousel.astro';
import Extras from '../components/Extras.astro';
import Clients from '../components/Clients.astro';
import Diagnostic from '../components/Diagnostic.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';

const lang = 'es';
---

<PageLayout lang={lang} path="">
  <Hero lang={lang} />
  <Guarantees lang={lang} />
  <Services lang={lang} />
  <Comparison lang={lang} />
  <ProjectsCarousel lang={lang} />
  <Extras lang={lang} />
  <Clients lang={lang} />
  <Diagnostic lang={lang} />
  <Faq lang={lang} />
  <FinalCta lang={lang} />
</PageLayout>
