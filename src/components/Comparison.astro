---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getComparison } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const { cols, rows } = getComparison(lang);
---

<section class="section compare">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('compare.kicker')}</span>
      <h2 class="section-title">{t('compare.title')}</h2>
      <p class="lead">{t('compare.subtitle')}</p>
    </div>

    <div class="compare__wrap card" data-reveal>
      <table class="compare__table">
        <thead>
          <tr>
            <th class="compare__feat-head">{t('compare.feature')}</th>
            <th class="compare__me-head">
              <span class="compare__me-badge">{cols[0]}</span>
            </th>
            <th>{cols[1]}</th>
            <th>{cols[2]}</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr>
                <td class="compare__feat">{row.feature}</td>
                <td class="compare__me" data-label={cols[0]}>
                  <Icon name="check" />
                  <span>{row.me}</span>
                </td>
                <td class="compare__other" data-label={cols[1]}>{row.template}</td>
                <td class="compare__other" data-label={cols[2]}>{row.agency}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .compare__wrap {
    padding: 0.5rem;
    overflow-x: auto;
  }
  .compare__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
  }
  .compare__table th,
  .compare__table td {
    padding: 1.05rem 1.2rem;
    text-align: left;
    font-size: 0.95rem;
  }
  .compare__table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text-muted);
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border);
  }
  .compare__feat-head {
    color: var(--text-dim) !important;
  }
  .compare__me-head {
    text-align: center !important;
  }
  .compare__me-badge {
    display: inline-block;
    background: var(--gradient);
    color: #0a0a12;
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 999px;
  }
  .compare__table tbody tr {
    border-bottom: 1px solid var(--border);
  }
  .compare__table tbody tr:last-child {
    border-bottom: none;
  }
  .compare__feat {
    font-weight: 600;
    color: var(--text);
  }
  .compare__me {
    text-align: center;
    background: var(--accent-soft);
  }
  .compare__me span {
    display: inline-block;
    vertical-align: middle;
    color: var(--text);
    font-weight: 600;
  }
  .compare__me :global(svg) {
    width: 1.05rem;
    height: 1.05rem;
    color: var(--accent-2);
    vertical-align: middle;
    margin-right: 0.4rem;
  }
  .compare__other {
    color: var(--text-dim);
  }
  /* Esquinas redondeadas de la columna destacada */
  .compare__table tbody tr:first-child .compare__me {
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
  }
  .compare__table tbody tr:last-child .compare__me {
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
  }

  /* ── Móvil: la tabla se apila en tarjetas (sin scroll horizontal) ── */
  @media (max-width: 700px) {
    .compare__wrap {
      overflow-x: visible;
      padding: 0;
      background: transparent;
      border: none;
    }
    .compare__table {
      min-width: 0;
    }
    .compare__table thead {
      display: none;
    }
    .compare__table tbody,
    .compare__table tr,
    .compare__table td {
      display: block;
      width: 100%;
    }
    .compare__table tbody tr {
      border: 1px solid var(--card-border);
      background: var(--surface);
      padding: 0.4rem 0.9rem 0.9rem;
      margin-bottom: 1rem;
    }
    .compare__table tbody tr:last-child {
      border: 1px solid var(--card-border);
    }
    .compare__feat {
      font-family: var(--font-display);
      font-size: 1.1rem;
      padding: 0.9rem 0 0.7rem;
      margin-bottom: 0.6rem;
      border-bottom: 1px solid var(--border);
    }
    .compare__table tbody td {
      padding: 0.5rem 0;
      font-size: 0.95rem;
    }
    /* Cada celda muestra su columna como etiqueta */
    .compare__table td.compare__me,
    .compare__table td.compare__other {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      text-align: left;
    }
    .compare__me::before,
    .compare__other::before {
      content: attr(data-label);
      flex: 0 0 40%;
      color: var(--text-dim);
      font-size: 0.82rem;
      font-weight: 600;
    }
    .compare__table td.compare__me {
      background: var(--accent-soft);
      padding: 0.65rem 0.75rem;
      margin-top: 0.5rem;
      align-items: center;
    }
    .compare__me::before {
      color: var(--accent-2);
    }
    .compare__me span {
      display: inline;
      flex: 1;
    }
    .compare__me :global(svg) {
      margin-right: 0;
    }
    /* Reset de radios redondeados heredados del layout de tabla */
    .compare__table tbody tr:first-child .compare__me,
    .compare__table tbody tr:last-child .compare__me {
      border-radius: 0;
    }
  }
</style>
