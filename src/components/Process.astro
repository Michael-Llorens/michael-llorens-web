---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getProcess } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const steps = getProcess(lang);
---

<section class="section process" id="process">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('process.kicker')}</span>
      <h2 class="section-title">{t('process.title')}</h2>
      <p class="lead">{t('process.subtitle')}</p>
    </div>

    <ol class="steps">
      {
        steps.map((s, i) => (
          <li class="step" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="step__num">{s.number}</span>
            <div class="step__content">
              <h3 class="step__title">{s.title}</h3>
              <p class="step__desc">{s.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    counter-reset: step;
    position: relative;
  }
  .step {
    position: relative;
    padding: 2rem 1.5rem;
    background: linear-gradient(180deg, var(--surface) 0%, var(--bg-soft) 100%);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: transform 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .step:hover {
    transform: translateY(-6px);
    border-color: var(--border-strong);
  }
  .step__num {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    opacity: 0.95;
  }
  .step__title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .step__desc {
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
