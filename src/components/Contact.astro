---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { site, whatsappLink } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const wa = whatsappLink(lang);

const directs = [
  { icon: 'mail', label: t('contact.email.label'), value: site.email, href: `mailto:${site.email}` },
  { icon: 'whatsapp', label: 'WhatsApp', value: site.phoneDisplay, href: wa },
  { icon: 'phone', label: t('contact.phone.label'), value: site.phoneDisplay, href: `tel:+${site.phoneRaw}` },
];

// Mensajes del formulario (envío AJAX a Web3Forms)
const formMsg = {
  es: {
    sending: 'Enviando…',
    ok: '¡Mensaje enviado! Te responderemos lo antes posible.',
    error: 'No se pudo enviar. Inténtalo de nuevo o escríbenos por email o WhatsApp.',
  },
  va: {
    sending: 'Enviant…',
    ok: 'Missatge enviat! Et respondrem com més prompte millor.',
    error: 'No s’ha pogut enviar. Torna-ho a provar o escriu-nos per email o WhatsApp.',
  },
  en: {
    sending: 'Sending…',
    ok: 'Message sent! We’ll get back to you as soon as possible.',
    error: 'Couldn’t send. Please try again or reach us by email or WhatsApp.',
  },
}[lang];
---

<!-- Contacto -->
<section class="section contact" id="contact">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('contact.kicker')}</span>
      <h1 class="section-title">{t('contact.title')}</h1>
      <p class="lead">{t('contact.subtitle')}</p>
    </div>

    <div class="contact__grid">
      <div class="contact__intro">
      {
        site.bookingUrl && (
          <a
            class="contact__book"
            href={site.bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-reveal
            style="--reveal-delay:150ms"
          >
            <span class="contact__book-ic"><Icon name="spark" /></span>
            <span class="contact__book-text">
              <strong>{t('contact.book')}</strong>
              <span>{t('contact.book.sub')}</span>
            </span>
            <Icon name="arrow" class="contact__book-arrow" />
          </a>
        )
      }

      <div class="contact__directs" data-reveal style="--reveal-delay:180ms">
        <span class="contact__directs-title">{t('contact.direct')}</span>
        {
          directs.map((d) => (
            <a
              class="contact__direct"
              href={d.href}
              target={d.icon === 'whatsapp' ? '_blank' : undefined}
              rel={d.icon === 'whatsapp' ? 'noopener noreferrer' : undefined}
            >
              <span class="contact__direct-ic"><Icon name={d.icon} /></span>
              <span>
                <span class="contact__direct-label">{d.label}</span>
                <strong>{d.value}</strong>
              </span>
            </a>
          ))
        }
        <div class="contact__location">
          <span class="contact__direct-ic"><Icon name="pin" /></span>
          <span>
            <span class="contact__direct-label">{t('contact.location.label')}</span>
            <strong>{t('contact.location.value')}</strong>
          </span>
        </div>
      </div>
    </div>

    <form class="contact__form card" id="contact-form" data-reveal style="--reveal-delay:120ms">
      <input type="hidden" name="access_key" value={site.web3formsKey} />
      <input type="hidden" name="subject" value="Nuevo mensaje desde la web de MetaLogic" />
      <input type="hidden" name="from_name" value="Web MetaLogic" />
      <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="field">
        <label for="name">{t('contact.form.name')}</label>
        <input type="text" id="name" name="name" required placeholder={t('contact.form.namePlaceholder')} autocomplete="name" />
      </div>
      <div class="field">
        <label for="email">{t('contact.form.email')}</label>
        <input type="email" id="email" name="email" required placeholder={t('contact.form.emailPlaceholder')} autocomplete="email" />
      </div>
      <div class="field">
        <label for="message">{t('contact.form.message')}</label>
        <textarea id="message" name="message" rows="5" required placeholder={t('contact.form.messagePlaceholder')}></textarea>
      </div>
      <label class="consent">
        <input type="checkbox" name="privacy_accepted" required />
        <span>
          {t('contact.form.consent.pre')}{' '}<a href="/politica-de-privacidad" target="_blank" rel="noopener noreferrer">{t('contact.form.consent.link')}</a>.
        </span>
      </label>
      <button type="submit" class="btn btn-primary btn-lg form__submit">
        {t('contact.form.send')}
        <Icon name="arrow" />
      </button>
      <p id="form-status" class="form__status" role="status" aria-live="polite"></p>
    </form>
    </div>
  </div>
</section>

<script define:vars={{ msg: formMsg }}>
  // Envío sin recargar la página vía Web3Forms. Los mensajes llegan al email.
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    const label = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = msg.sending;
    status.textContent = '';
    status.className = 'form__status';
    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        form.reset();
        status.textContent = msg.ok;
        status.classList.add('form__status--ok');
      } else {
        status.textContent = msg.error;
        status.classList.add('form__status--err');
      }
    } catch (err) {
      status.textContent = msg.error;
      status.classList.add('form__status--err');
    } finally {
      btn.disabled = false;
      btn.innerHTML = label;
    }
  });
</script>

<style>
  /* Contacto */
  .contact .section-head {
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  /* Sin cabecera ya en la columna: el primer bloque arranca alineado arriba. */
  .contact__intro > :first-child {
    margin-top: 0;
  }
  .contact__book {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1.1rem 1.3rem;
    border-radius: var(--radius);
    background:
      linear-gradient(var(--surface), var(--bg-soft)) padding-box,
      var(--gradient) border-box;
    border: 1.5px solid transparent;
    box-shadow: 0 14px 40px -18px var(--accent-glow);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .contact__book:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 48px -18px var(--accent-glow);
  }
  .contact__book-ic {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--gradient);
    color: #0a0a12;
    flex-shrink: 0;
  }
  .contact__book-ic :global(svg) {
    width: 24px;
    height: 24px;
  }
  .contact__book-text {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .contact__book-text strong {
    font-family: var(--font-display);
    font-size: 1.05rem;
  }
  .contact__book-text span {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .contact__book-arrow {
    width: 1.2rem;
    height: 1.2rem;
    margin-left: auto;
    color: var(--accent-2);
    transition: transform 0.25s var(--ease);
  }
  .contact__book:hover .contact__book-arrow {
    transform: translateX(4px);
  }

  .contact__directs {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .contact__directs-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
  }
  .contact__direct,
  .contact__location {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    transition: border-color 0.25s ease, transform 0.25s var(--ease), background 0.25s;
  }
  .contact__direct:hover {
    border-color: var(--accent);
    transform: translateX(4px);
    background: var(--surface-2);
  }
  .contact__direct-ic {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 11px;
    background: var(--accent-soft);
    color: var(--accent-2);
    flex-shrink: 0;
  }
  .contact__direct-ic :global(svg) {
    width: 20px;
    height: 20px;
  }
  .contact__direct-label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-dim);
  }
  .contact__direct strong {
    font-size: 0.98rem;
  }

  /* Formulario */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .field label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--text);
  }
  .field input,
  .field textarea {
    background: var(--input-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    color: var(--text);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--text-dim);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .consent {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    cursor: pointer;
    line-height: 1.4;
  }
  .consent input {
    margin-top: 0.2rem;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    accent-color: var(--accent);
  }
  .consent a {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .consent a:hover {
    color: var(--accent-2);
  }
  .form__submit {
    margin-top: 0.4rem;
    align-self: center;
  }
  /* Honeypot antispam: oculto para humanos, visible para bots */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
  .form__status {
    margin-top: 0.3rem;
    font-size: 0.92rem;
    min-height: 1.2em;
    font-weight: 500;
  }
  .form__status--ok {
    color: #1c9e57;
  }
  .form__status--err {
    color: #e0492a;
  }

  @media (max-width: 800px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
