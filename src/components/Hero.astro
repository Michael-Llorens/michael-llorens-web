---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getProjects } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Capturas reales para la rueda del hero (las tarjetas van rotando solas).
const shots = getProjects(lang)
  .filter((p) => p.image)
  .map((p) => ({ name: p.name, image: p.image as string }));
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="aurora"></div>
    <div class="orb orb--1"></div>
    <div class="orb orb--2"></div>
    <div class="grid-lines"></div>
  </div>

  <div class="container hero__inner">
    <div class="hero__text">
      <span class="hero__badge" data-reveal style="--reveal-delay:0ms">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        {t('hero.badge')}
      </span>

      <h1 class="display hero__title" data-reveal style="--reveal-delay:60ms">
        {t('hero.title.1')}{' '}
        <span class="gradient-text">{t('hero.title.2')}</span>{' '}
        {t('hero.title.3')}
      </h1>

      <p class="hero__subtitle" data-reveal style="--reveal-delay:140ms">
        {t('hero.subtitle')}
      </p>

      <div class="hero__cta" data-reveal style="--reveal-delay:220ms">
        <a href={localizedPath(lang, 'contacto')} class="btn btn-primary">
          {t('hero.cta.primary')}
          <Icon name="arrow" />
        </a>
        <a href={localizedPath(lang, 'proyectos')} class="btn btn-ghost">{t('hero.cta.secondary')}</a>
      </div>

      <p class="hero__trust" data-reveal style="--reveal-delay:300ms">
        <Icon name="check" class="trust-ic" />
        {t('hero.trust')}
      </p>
      <p class="hero__guarantee" data-reveal style="--reveal-delay:360ms">{t('hero.guarantee')}</p>
    </div>

    <div class="hero__visual" data-reveal style="--reveal-delay:260ms">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="hero__deck">
        {
          shots.map((s, i) => (
            <figure class="hero__card" data-i={i}>
              <img
                src={s.image}
                alt={`Web de ${s.name} diseñada por MetaLogic`}
                width="1280"
                height="800"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'low'}
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Rueda 3D del hero: la tarjeta de abajo sube al frente, la activa retrocede
  // hacia arriba/atrás. Cada 3 s. Respeta "reducir movimiento" (se queda fija).
  const deck = document.querySelector('.hero__deck');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (deck) {
    const cards = Array.from(deck.querySelectorAll<HTMLElement>('.hero__card'));
    const N = cards.length;
    let active = 0;
    const apply = () => {
      cards.forEach((card, i) => {
        const r = (i - active + N) % N; // 0 = frente
        let pos;
        if (r === 0) pos = '0'; // activa, al frente
        else if (r === 1) pos = 'prev'; // saliente, arriba
        else if (r === N - 1) pos = 'next'; // entrante, abajo
        else if (r === 2) pos = 'htop'; // oculta, rodando por arriba
        else pos = 'hbot'; // oculta, esperando por abajo
        card.dataset.pos = pos;
      });
    };
    apply();
    if (!prefersReduced && N > 1) {
      window.setInterval(() => {
        active = (active - 1 + N) % N; // la de abajo pasa al frente
        apply();
      }, 3000);
    }
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: auto;
    display: flex;
    align-items: center;
    padding-top: clamp(5rem, 7vw, 6.5rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: float 14s ease-in-out infinite;
  }
  .orb--1 {
    width: 38rem;
    height: 38rem;
    top: -12rem;
    right: -10rem;
    background: radial-gradient(circle, rgba(251, 84, 18, 0.5), transparent 70%);
  }
  .orb--2 {
    width: 32rem;
    height: 32rem;
    bottom: -14rem;
    left: -8rem;
    background: radial-gradient(circle, rgba(255, 138, 76, 0.4), transparent 70%);
    animation-delay: -6s;
  }
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-2rem, 2rem) scale(1.08); }
  }

  /* Aurora: degradado naranja que deriva lentamente */
  .aurora {
    position: absolute;
    inset: -25%;
    background:
      radial-gradient(38% 50% at 28% 32%, rgba(251, 84, 18, 0.22), transparent 60%),
      radial-gradient(34% 46% at 72% 42%, rgba(255, 138, 76, 0.16), transparent 62%),
      radial-gradient(46% 42% at 52% 78%, rgba(255, 120, 56, 0.12), transparent 65%);
    filter: blur(48px);
    will-change: transform;
  }
  @media (prefers-reduced-motion: no-preference) {
    .aurora {
      animation: aurora-move 20s ease-in-out infinite alternate;
    }
  }
  @keyframes aurora-move {
    0% { transform: translate3d(-4%, -2%, 0) scale(1); }
    50% { transform: translate3d(4%, 3%, 0) scale(1.12); }
    100% { transform: translate3d(-2%, 5%, 0) scale(1.06); }
  }
  .grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 3.5rem);
    align-items: center;
    text-align: center;
    max-width: 1180px;
    width: 100%;
    padding-block: 1rem;
  }
  .hero__text {
    min-width: 0;
  }

  /* ── Visual: rueda 3D de capturas reales (tarjetas que rotan) ── */
  .hero__visual {
    position: relative;
    width: 100%;
    max-width: 470px;
    margin-inline: auto;
    padding-block: 3rem;
  }
  .hero__glow {
    position: absolute;
    inset: 0 -10%;
    background: radial-gradient(58% 58% at 50% 45%, var(--accent-glow), transparent 70%);
    filter: blur(42px);
    opacity: 0.5;
    z-index: -1;
  }
  .hero__deck {
    position: relative;
    height: clamp(360px, 44vw, 500px);
    perspective: 1100px;
  }
  .hero__card {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    width: 100%;
    aspect-ratio: 1280 / 800;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: #0c0c16;
    box-shadow: 0 24px 50px -22px rgba(0, 0, 0, 0.65);
    opacity: 0;
    transform: translateY(-50%) translateZ(-280px) rotateX(40deg) scale(0.66);
    will-change: transform, opacity;
  }
  /* Mayor especificidad para ganar a la transición global de tema
     (:root[data-theme] body *), que si no anula el giro y lo deja brusco. */
  .hero__deck .hero__card {
    transition: transform 1.45s cubic-bezier(0.45, 0.05, 0.3, 1),
      opacity 1.45s ease-in-out;
  }
  .hero__card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  /* posiciones de la rueda — las asigna el script con data-pos.
     Solo 3 visibles: arriba (saliente) · centro (activa) · abajo (entrante).
     Las tarjetas ruedan en un cilindro: arriba y abajo tienen el mismo tamaño. */
  .hero__card[data-pos='0'] {
    opacity: 1;
    transform: translateY(-50%) translateZ(50px) rotateX(0) scale(1);
    z-index: 50;
  }
  .hero__card[data-pos='prev'] {
    opacity: 0.62;
    transform: translateY(calc(-50% - 162px)) translateZ(-110px) rotateX(24deg) scale(0.8);
    z-index: 30;
  }
  .hero__card[data-pos='next'] {
    opacity: 0.62;
    transform: translateY(calc(-50% + 162px)) translateZ(-110px) rotateX(-24deg) scale(0.8);
    z-index: 30;
  }
  /* estados ocultos (no se ven): continúan el giro por arriba y por abajo */
  .hero__card[data-pos='htop'] {
    opacity: 0;
    transform: translateY(calc(-50% - 300px)) translateZ(-280px) rotateX(40deg) scale(0.66);
    z-index: 10;
  }
  .hero__card[data-pos='hbot'] {
    opacity: 0;
    transform: translateY(calc(-50% + 300px)) translateZ(-280px) rotateX(-40deg) scale(0.66);
    z-index: 10;
  }

  /* ── Escritorio: dos columnas equilibradas, texto a la izquierda ── */
  @media (min-width: 980px) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
      text-align: left;
      gap: 3rem;
      align-items: center;
    }
    .hero__title {
      font-size: clamp(2.3rem, 4vw, 3.5rem);
    }
    .hero__inner .hero__subtitle {
      margin-inline: 0;
    }
    .hero__inner .hero__cta {
      justify-content: flex-start;
    }
    .hero__visual {
      max-width: none;
    }
  }
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    margin-bottom: 1.2rem;
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
  }
  .hero__badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-2);
    flex-shrink: 0;
    animation: badge-pulse 2.4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__badge-dot {
      animation: none;
    }
  }
  @keyframes badge-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero__title {
    margin-bottom: 1.5rem;
  }
  .hero__subtitle {
    color: var(--text-muted);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    max-width: 660px;
    margin-inline: auto;
    margin-bottom: 2.4rem;
  }
  .hero__cta {
    display: flex;
    gap: 0.7rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .hero__trust {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text-dim);
    font-size: 0.9rem;
  }
  .hero__guarantee {
    margin-top: 0.7rem;
    color: var(--text-dim);
    font-size: 0.82rem;
    opacity: 0.85;
  }
  .hero__trust :global(svg) {
    width: 1.05rem;
    height: 1.05rem;
    color: var(--accent-2);
  }

</style>
