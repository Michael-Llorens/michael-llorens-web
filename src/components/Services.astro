---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getServices } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  /** En la página de Servicios este título es el H1 de la página. */
  asPageTitle?: boolean;
}
const { lang, asPageTitle = false } = Astro.props;
const t = useTranslations(lang);
const services = getServices(lang);
const TitleTag = asPageTitle ? 'h1' : 'h2';
---

<section class="section" id="services">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('services.kicker')}</span>
      <TitleTag class="section-title">{t('services.title')}</TitleTag>
      <p class="lead">{t('services.subtitle')}</p>
    </div>

    <div class="services__tabs card card-glow" data-reveal>
      <div class="services__pills" role="tablist" aria-label={t('services.title')}>
        {
          services.map((s, i) => (
            <button
              type="button"
              id={s.slug}
              class:list={['pill', i === 0 && 'is-active']}
              data-index={i}
              data-slug={s.slug}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${s.slug}`}
            >
              <Icon name={s.icon} />
              <span>{s.title}</span>
            </button>
          ))
        }
      </div>

      <div class="services__panels">
        {
          services.map((s, i) => (
            <div id={`panel-${s.slug}`} class:list={['panel', i === 0 && 'is-active']} data-index={i} role="tabpanel">
              <span class="panel__icon" aria-hidden="true">
                <Icon name={s.icon} />
              </span>
              <div class="panel__body">
                {s.badge && <span class="panel__badge">{s.badge}</span>}
                <h3 class="panel__title">{s.title}</h3>
                <p class="panel__desc">{s.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Pestañas de servicios: click cambia el panel visible. Sin JS, se ve
  // el primer servicio completo (nada queda oculto de forma rota).
  document.querySelectorAll<HTMLElement>('.services__tabs').forEach((wrap) => {
    const pills = Array.from(wrap.querySelectorAll<HTMLElement>('.pill'));
    const panels = Array.from(wrap.querySelectorAll<HTMLElement>('.panel'));

    const activate = (index: string) => {
      pills.forEach((p) => {
        const active = p.dataset.index === index;
        p.classList.toggle('is-active', active);
        p.setAttribute('aria-selected', String(active));
      });
      panels.forEach((p) => p.classList.toggle('is-active', p.dataset.index === index));
    };

    pills.forEach((pill) => {
      pill.addEventListener('click', () => activate(pill.dataset.index || '0'));
    });

    // Deep-link: los enlaces del footer llegan como /servicios#seo.
    // El navegador ya hace scroll a la pestaña (tiene ese id); aquí solo
    // activamos su panel en vez del primero.
    const hash = location.hash.replace('#', '');
    if (hash) {
      const match = pills.find((p) => p.dataset.slug === hash);
      if (match) activate(match.dataset.index || '0');
    }
  });
</script>

<style>
  .services__tabs {
    padding: 0;
    overflow: hidden;
  }
  .services__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: clamp(1.2rem, 3vw, 1.6rem);
    border-bottom: 1px solid var(--border);
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 1.05rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.88rem;
    cursor: pointer;
    transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease;
    scroll-margin-top: 6rem;
  }
  .pill:hover {
    border-color: var(--accent);
    color: var(--text);
  }
  .pill :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }
  .pill.is-active {
    background: var(--gradient);
    border-color: transparent;
    color: #0a0a12;
  }

  .services__panels {
    position: relative;
    padding: clamp(1.6rem, 4vw, 2.6rem);
  }
  .panel {
    display: none;
    gap: 1.4rem;
    align-items: flex-start;
  }
  .panel.is-active {
    display: flex;
  }
  .panel__icon {
    display: grid;
    place-items: center;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-2);
    flex-shrink: 0;
  }
  .panel__icon :global(svg) {
    width: 30px;
    height: 30px;
  }
  .panel__body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .panel__badge {
    display: inline-block;
    width: fit-content;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0a0a12;
    background: var(--gradient);
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
  }
  .panel__title {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
  }
  .panel__desc {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 62ch;
  }

  @media (max-width: 700px) {
    .panel {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
