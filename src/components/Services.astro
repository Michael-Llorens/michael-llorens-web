---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getServices } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  /** En la página de Servicios este título es el H1 de la página. */
  asPageTitle?: boolean;
}
const { lang, asPageTitle = false } = Astro.props;
const t = useTranslations(lang);
const services = getServices(lang);
const TitleTag = asPageTitle ? 'h1' : 'h2';
---

<section class="section" id="services">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('services.kicker')}</span>
      <TitleTag class="section-title">{t('services.title')}</TitleTag>
      <p class="lead">{t('services.subtitle')}</p>
    </div>

    <div class="grid grid-3">
      {
        services.map((s, i) => (
          <article id={s.slug} class="card card-glow service" data-reveal style={`--reveal-delay:${i * 70}ms`}>
            <div class="service__icon">
              <Icon name={s.icon} />
            </div>
            <h3 class="service__title">{s.title}</h3>
            <p class="service__desc">{s.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    scroll-margin-top: 6rem; /* deja hueco bajo el header fijo al llegar por ancla */
  }
  .service__icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 15px;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-2);
    margin-bottom: 0.4rem;
  }
  .service__icon :global(svg) {
    width: 26px;
    height: 26px;
  }
  .service__title {
    font-size: 1.25rem;
  }
  .service__desc {
    color: var(--text-muted);
    font-size: 0.96rem;
  }
</style>
