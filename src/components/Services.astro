---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getPillars } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  /** En la página de Servicios este título es el H1 de la página. */
  asPageTitle?: boolean;
}
const { lang, asPageTitle = false } = Astro.props;
const t = useTranslations(lang);
const pillars = getPillars(lang);
const TitleTag = asPageTitle ? 'h1' : 'h2';
---

<section class="section" id="services">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('services.kicker')}</span>
      <TitleTag class="section-title">{t('services.title')}</TitleTag>
      <p class="lead">{t('services.subtitle')}</p>
    </div>

    <div class="pillars">
      {
        pillars.map((p, i) => (
          <article id={p.slug} class="pillar card card-glow" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="pillar__watermark" aria-hidden="true">
              <Icon name={p.icon} />
            </span>
            <div class="pillar__icon">
              <Icon name={p.icon} />
            </div>
            {p.badge && <span class="pillar__badge">{p.badge}</span>}
            <h3 class="pillar__title">{p.title}</h3>
            <p class="pillar__desc">{p.description}</p>
            <ul class="pillar__tags">
              {p.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  .pillar {
    position: relative;
    z-index: 0; /* contiene el watermark en su propio contexto de apilamiento */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: clamp(1.7rem, 3vw, 2.2rem);
    scroll-margin-top: 6rem; /* deja hueco bajo el header fijo al llegar por ancla */
  }
  .pillar__watermark {
    position: absolute;
    bottom: -2rem;
    right: -2rem;
    width: 9rem;
    height: 9rem;
    color: var(--accent);
    opacity: 0.06;
    z-index: -1;
    pointer-events: none;
  }
  .pillar__watermark :global(svg) {
    width: 100%;
    height: 100%;
  }
  .pillar__icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 15px;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-2);
  }
  .pillar__icon :global(svg) {
    width: 26px;
    height: 26px;
  }
  .pillar__badge {
    display: inline-block;
    width: fit-content;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0a0a12;
    background: var(--gradient);
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
  }
  .pillar__title {
    font-size: 1.35rem;
  }
  .pillar__desc {
    color: var(--text-muted);
    font-size: 0.96rem;
    flex-grow: 1;
  }
  .pillar__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.3rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
  }
  .pillar__tags li {
    font-size: 0.76rem;
    color: var(--text-dim);
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
  }

  @media (max-width: 860px) {
    .pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
