---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getGuarantees } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = getGuarantees(lang);
---

<section class="section guarantees">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('guarantees.kicker')}</span>
      <h2 class="section-title">{t('guarantees.title')}</h2>
    </div>

    <div class="guarantees__strip card card-glow" data-reveal>
      {
        items.map((g) => (
          <div class="guarantee">
            <span class="guarantee__ic">
              <Icon name={g.icon} />
            </span>
            <h3 class="guarantee__title">{g.title}</h3>
            <p class="guarantee__desc">{g.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .guarantees__strip {
    display: flex;
    padding: clamp(1.8rem, 4vw, 2.4rem) clamp(1.2rem, 3vw, 2rem);
  }
  .guarantee {
    position: relative;
    flex: 1;
    text-align: center;
    padding-inline: clamp(0.8rem, 2vw, 1.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
  }
  .guarantee:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 8%;
    height: 84%;
    width: 1px;
    background: var(--border);
  }
  .guarantee__ic {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-2);
    margin-bottom: 0.3rem;
  }
  .guarantee__ic :global(svg) {
    width: 25px;
    height: 25px;
  }
  .guarantee__title {
    font-size: 1.05rem;
  }
  .guarantee__desc {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  @media (max-width: 780px) {
    .guarantees__strip {
      flex-direction: column;
      gap: 1.6rem;
    }
    .guarantee {
      padding-inline: 0;
    }
    .guarantee:not(:last-child)::after {
      right: auto;
      top: auto;
      bottom: -0.8rem;
      left: 15%;
      width: 70%;
      height: 1px;
    }
  }
</style>
