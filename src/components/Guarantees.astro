---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getGuarantees } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = getGuarantees(lang);
---

<section class="section guarantees">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('guarantees.kicker')}</span>
      <h2 class="section-title">{t('guarantees.title')}</h2>
    </div>

    <div class="promises" data-reveal>
      {
        items.map((g) => (
          <div class="promise">
            <span class="promise__ic">
              <Icon name={g.icon} />
            </span>
            <h3 class="promise__title">{g.title}</h3>
            <p class="promise__desc">{g.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .promises {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(2rem, 4vw, 2.6rem);
  }
  .promise {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.7rem;
  }
  .promise__ic {
    display: grid;
    place-items: center;
    color: var(--accent-2);
    transition: transform 0.3s var(--ease), color 0.3s ease;
  }
  .promise__ic :global(svg) {
    width: 52px;
    height: 52px;
    stroke-width: 1.4;
  }
  .promise:hover .promise__ic {
    color: var(--accent);
    transform: translateY(-3px) scale(1.06);
  }
  .promise__title {
    font-size: 1.08rem;
  }
  .promise__desc {
    color: var(--text-muted);
    font-size: 0.88rem;
    max-width: 24ch;
  }

  @media (max-width: 780px) {
    .promises {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 2.6rem;
    }
  }
  @media (max-width: 460px) {
    .promises {
      grid-template-columns: 1fr;
    }
  }
</style>
