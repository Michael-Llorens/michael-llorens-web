---
import '@fontsource/quicksand/latin-600.css';
import type { Lang } from '../i18n/config';
import { whatsappLink } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const wa = whatsappLink(lang);

const copy: Record<Lang, { text: string; close: string }> = {
  es: { text: '¿Hablamos por WhatsApp?', close: 'Cerrar mensaje' },
  va: { text: 'Parlem per WhatsApp?', close: 'Tancar missatge' },
  en: { text: "Let's chat on WhatsApp", close: 'Close message' },
};
const t = copy[lang];
---

<!-- Popup tipo tooltip (aparece a los 3 s, se auto-oculta a los 7 s) -->
<div class="whatsapp-tooltip" id="wa-tooltip" hidden>
  <button class="whatsapp-tooltip-close" type="button" aria-label={t.close}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  </button>
  <a class="whatsapp-tooltip-link" href={wa} target="_blank" rel="noopener noreferrer">
    <span class="whatsapp-tooltip-emoji" aria-hidden="true">👋</span>
    <span class="whatsapp-tooltip-text">{t.text}</span>
  </a>
</div>

<a class="whatsapp-float" href={wa} target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp">
  <Icon name="whatsapp" />
</a>

<script>
  const tip = document.getElementById('wa-tooltip');
  if (tip) {
    const closeBtn = tip.querySelector('.whatsapp-tooltip-close');
    let auto: number | undefined;
    const hide = () => {
      window.clearTimeout(auto);
      tip.classList.remove('is-visible');
      window.setTimeout(() => tip.setAttribute('hidden', ''), 400);
    };
    closeBtn?.addEventListener('click', hide);
    window.setTimeout(() => {
      tip.removeAttribute('hidden');
      void tip.offsetWidth;
      tip.classList.add('is-visible');
      auto = window.setTimeout(hide, 7000);
    }, 3000);
  }
</script>

<style>
  /* ── Botón flotante (idéntico a clinicalauraserra.com) ── */
  .whatsapp-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    background: transparent;
    color: #25d366;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 95;
    filter: drop-shadow(rgba(37, 211, 102, 0.45) 0px 6px 14px);
    transition: filter 0.3s ease;
  }
  .whatsapp-float :global(svg) {
    width: 48px;
    height: 48px;
    fill: currentColor;
    stroke: none;
  }
  .whatsapp-float:hover {
    filter: drop-shadow(rgba(37, 211, 102, 0.65) 0px 8px 22px);
  }

  /* ── Popup flotante ── */
  .whatsapp-tooltip {
    position: fixed;
    bottom: 92px;
    right: 16px;
    z-index: 95;
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: calc(100vw - 32px);
    padding: 9px 12px 9px 10px;
    border-radius: 14px;
    background: linear-gradient(135deg, #a3380f 0%, #7c2d12 100%);
    box-shadow: rgba(124, 45, 18, 0.45) 0px 8px 24px, rgba(124, 45, 18, 0.2) 0px 1px 3px;
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.4s ease-out, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .whatsapp-tooltip.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .whatsapp-tooltip::after {
    content: '';
    position: absolute;
    bottom: -5px;
    right: 36px;
    width: 12px;
    height: 12px;
    background: #7c2d12;
    transform: rotate(45deg);
    box-shadow: rgba(124, 45, 18, 0.18) 4px 4px 7px;
    border-bottom-right-radius: 3px;
  }
  .whatsapp-tooltip-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    text-decoration: none;
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.92rem;
    white-space: nowrap;
    padding: 2px 2px 2px 0;
  }
  .whatsapp-tooltip-link:hover {
    color: #ffc7a8;
  }
  .whatsapp-tooltip-emoji {
    font-size: 1.05rem;
    line-height: 1;
  }
  .whatsapp-tooltip-close {
    appearance: none;
    background: transparent;
    border: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.7);
    flex-shrink: 0;
    padding: 0;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .whatsapp-tooltip-close:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
  .whatsapp-tooltip-close svg {
    width: 11px;
    height: 11px;
  }
</style>
