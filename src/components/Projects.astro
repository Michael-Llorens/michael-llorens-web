---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getProjects } from '../data/content';
import ProjectCard from './ProjectCard.astro';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const projects = getProjects(lang);

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section class="section" id="work">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('work.kicker')}</span>
      <h2 class="section-title">{t('work.title')}</h2>
      <p class="lead">{t('work.subtitle')}</p>
    </div>

    {
      featured.length > 0 && (
        <div class="projects-featured">
          {featured.map((p, i) => <ProjectCard project={p} lang={lang} index={i} />)}
        </div>
      )
    }

    <div class="grid projects">
      {rest.map((p, i) => <ProjectCard project={p} lang={lang} index={i} />)}
    </div>

    <div class="work-cta" data-reveal>
      <p>{t('work.cta')}</p>
      <a href="#contact" class="btn btn-primary">
        {t('nav.cta')}
        <Icon name="arrow" />
      </a>
    </div>
  </div>
</section>

<style>
  .projects-featured {
    display: grid;
    margin-bottom: 1.8rem;
  }
  .projects {
    grid-template-columns: repeat(2, 1fr);
    gap: 1.8rem;
  }
  @media (max-width: 760px) {
    .projects {
      grid-template-columns: 1fr;
    }
  }
  .work-cta {
    margin-top: 3.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }
  .work-cta p {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 600;
    color: var(--text);
  }
</style>
