---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getSkills } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const skills = getSkills(lang);
---

<section class="section" id="about">
  <div class="container about">
    <div class="about__visual" data-reveal>
      <img class="about__logo" src="/logo-full.png" alt="Logo de MetaLogic" width="623" height="645" loading="lazy" />
    </div>

    <div class="about__content">
      <span class="kicker" data-reveal>{t('about.kicker')}</span>
      <h1 class="section-title" data-reveal style="--reveal-delay:60ms">{t('about.title')}</h1>
      <p class="about__p" data-reveal style="--reveal-delay:120ms">{t('about.p1')}</p>
      <p class="about__p" data-reveal style="--reveal-delay:180ms">{t('about.p2')}</p>

      <div class="about__skills" data-reveal style="--reveal-delay:240ms">
        <span class="about__skills-title">{t('about.skills.title')}</span>
        <div class="about__chips">
          {skills.map((s) => <span class="tag">{s}</span>)}
        </div>
      </div>

      <a href={localizedPath(lang, 'contacto')} class="btn btn-primary about__cta" data-reveal style="--reveal-delay:300ms">
        {t('about.cta')}
        <Icon name="arrow" />
      </a>
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .about__visual {
    position: relative;
    display: grid;
    place-items: center;
  }
  /* Logo grande, sin recuadro: flota con una sombra suave */
  .about__logo {
    width: min(400px, 88%);
    height: auto;
    filter: drop-shadow(0 18px 40px rgba(251, 84, 18, 0.2));
  }
  .about__p {
    color: var(--text-muted);
    margin-top: 1rem;
    font-size: 1.02rem;
  }
  .about__skills {
    margin-top: 2rem;
  }
  .about__skills-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 0.9rem;
  }
  .about__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.1rem;
  }
  /* Tecnologías en naranja, sin recuadro */
  .about__chips .tag {
    background: none;
    border: none;
    padding: 0;
    color: var(--accent-2);
    font-weight: 600;
  }
  .about__cta {
    margin-top: 2.2rem;
  }

  @media (max-width: 860px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__visual {
      order: -1;
      margin-bottom: 1rem;
    }
  }
</style>
