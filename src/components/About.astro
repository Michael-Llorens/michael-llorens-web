---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getSkills } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const skills = getSkills(lang);
const seoLabel = lang === 'en' ? 'Technical SEO' : lang === 'va' ? 'SEO tècnic' : 'SEO técnico';
---

<section class="section" id="about">
  <div class="container about">
    <div class="about__visual" data-reveal>
      <div class="about__portrait">
        <img class="about__logo" src="/logo-full.png" alt="Logo de MetaLogic" width="623" height="645" loading="lazy" />
        <div class="about__ring"></div>
      </div>
      <div class="about__badge card">
        <Icon name="spark" class="about__badge-ic" />
        <div>
          <strong>Astro</strong>
          <span>+ {seoLabel}</span>
        </div>
      </div>
    </div>

    <div class="about__content">
      <span class="kicker" data-reveal>{t('about.kicker')}</span>
      <h1 class="section-title" data-reveal style="--reveal-delay:60ms">{t('about.title')}</h1>
      <p class="about__p" data-reveal style="--reveal-delay:120ms">{t('about.p1')}</p>
      <p class="about__p" data-reveal style="--reveal-delay:180ms">{t('about.p2')}</p>

      <div class="about__skills" data-reveal style="--reveal-delay:240ms">
        <span class="about__skills-title">{t('about.skills.title')}</span>
        <div class="about__chips">
          {skills.map((s) => <span class="tag">{s}</span>)}
        </div>
      </div>

      <a href={localizedPath(lang, 'contacto')} class="btn btn-primary about__cta" data-reveal style="--reveal-delay:300ms">
        {t('about.cta')}
        <Icon name="arrow" />
      </a>
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .about__visual {
    position: relative;
    display: grid;
    place-items: center;
  }
  .about__portrait {
    position: relative;
    width: min(320px, 80%);
    aspect-ratio: 1;
    border-radius: 0;
    background:
      radial-gradient(circle at 30% 25%, rgba(251, 84, 18, 0.55), transparent 60%),
      radial-gradient(circle at 75% 80%, rgba(255, 138, 76, 0.4), transparent 60%),
      #14141f;
    border: 1px solid var(--card-border);
    display: grid;
    place-items: center;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .about__logo {
    position: relative;
    z-index: 1;
    width: 76%;
    height: auto;
  }
  .about__ring {
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    padding: 2px;
    background: var(--gradient);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.6;
  }
  .about__badge {
    position: absolute;
    top: 1rem;
    right: 0;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.1rem;
    background: var(--surface);
    backdrop-filter: blur(8px);
  }
  .about__badge :global(svg) {
    width: 26px;
    height: 26px;
    color: var(--accent-2);
  }
  .about__badge strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
  }
  .about__badge span {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .about__p {
    color: var(--text-muted);
    margin-top: 1rem;
    font-size: 1.02rem;
  }
  .about__skills {
    margin-top: 2rem;
  }
  .about__skills-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 0.9rem;
  }
  .about__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .about__cta {
    margin-top: 2.2rem;
  }

  @media (max-width: 860px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__visual {
      order: -1;
      margin-bottom: 1rem;
    }
  }
</style>
