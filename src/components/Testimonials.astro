---
import type { Lang } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getTestimonials } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const testimonials = getTestimonials(lang);
---

<section class="section testimonials" aria-labelledby="testimonials-title">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('testimonials.kicker')}</span>
      <h2 class="section-title" id="testimonials-title">{t('testimonials.title')}</h2>
      <p class="lead">{t('testimonials.subtitle')}</p>
    </div>

    <div class="grid grid-3">
      {
        testimonials.map((tm, i) => (
          <figure class="card card-glow tcard" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <div class="tcard__stars" role="img" aria-label="5 de 5 estrellas">
              {Array.from({ length: 5 }).map(() => <Icon name="star" />)}
            </div>
            <blockquote class="tcard__quote">“{tm.quote}”</blockquote>
            <figcaption class="tcard__author">
              <span class="tcard__avatar">{tm.author.charAt(0)}</span>
              <span>
                <strong>{tm.author}</strong>
                <span class="tcard__role">{tm.role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tcard {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tcard__stars {
    display: flex;
    gap: 3px;
    color: #ffcb45;
  }
  .tcard__stars :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    fill: currentColor;
    stroke: none;
  }
  .tcard__quote {
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.6;
    flex: 1;
  }
  .tcard__author {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--border);
  }
  .tcard__avatar {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--gradient);
    color: #0a0a12;
    font-family: var(--font-display);
    font-weight: 700;
    flex-shrink: 0;
  }
  .tcard__author strong {
    display: block;
    font-size: 0.95rem;
  }
  .tcard__role {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
</style>
