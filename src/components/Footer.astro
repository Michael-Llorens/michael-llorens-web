---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getPillars } from '../data/content';
import { site, whatsappLink } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = 2026; // Date.now() no disponible en build; actualiza si lo necesitas.

const navLinks = [
  { href: localizedPath(lang), label: t('nav.home') },
  { href: localizedPath(lang, 'servicios'), label: t('nav.services') },
  { href: localizedPath(lang, 'proyectos'), label: t('nav.work') },
  { href: localizedPath(lang, 'precios'), label: t('nav.pricing') },
  { href: localizedPath(lang, 'nosotros'), label: t('nav.about') },
  { href: localizedPath(lang, 'contacto'), label: t('nav.contact') },
];

const legalLinks = [
  { href: '/aviso-legal', label: t('legal.notice') },
  { href: '/politica-de-privacidad', label: t('legal.privacy') },
  { href: '/politica-de-cookies', label: t('legal.cookies') },
];

const services = getPillars(lang);

const socials = [
  { name: 'instagram', href: site.socials.instagram },
  { name: 'whatsapp', href: whatsappLink(lang) },
  { name: 'mail', href: `mailto:${site.email}` },
].filter((s) => s.href);
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href={localizedPath(lang)} class="footer__logo" aria-label={site.name}>
          <img src="/logo-full.png" alt={site.name} width="623" height="645" loading="lazy" />
        </a>
        <div class="footer__socials">
          {
            socials.map((s) => (
              <a
                href={s.href}
                class="footer__social"
                aria-label={s.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name={s.name} />
              </a>
            ))
          }
        </div>
        <p class="footer__tagline">{t('footer.tagline')}</p>
      </div>

      <div class="footer__col">
        <h3 class="footer__title">{t('footer.nav')}</h3>
        <ul>
          {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__title">{t('footer.services')}</h3>
        <ul>
          {
            services.map((s) => (
              <li>
                <a href={`${localizedPath(lang, 'servicios')}#${s.slug}`}>{s.title}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__title">{t('footer.contact')}</h3>
        <ul>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><a href={`tel:+${site.phoneRaw}`}>{site.phoneDisplay}</a></li>
          <li>{site.location}</li>
        </ul>
      </div>
    </div>

    <hr class="divider" />

    <div class="footer__bottom">
      <p>© {year} {site.name}. {t('footer.rights')}</p>
      <nav class="footer__legal" aria-label="Legal">
        {legalLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <p class="footer__made">{t('footer.madeWith')}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg);
    padding-block: clamp(3rem, 6vw, 4.5rem) 2rem;
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
  }
  .footer__logo {
    display: inline-block;
  }
  .footer__logo img {
    width: 150px;
    height: auto;
    display: block;
  }
  .footer__tagline {
    color: var(--text-muted);
    margin: 1.1rem 0 0;
    font-size: 0.95rem;
    max-width: 32ch;
  }
  .footer__socials {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-top: 1.2rem;
  }
  .footer__social {
    display: grid;
    place-items: center;
    color: var(--accent);
    transition: color 0.25s, transform 0.25s var(--ease);
  }
  .footer__social :global(svg) {
    width: 24px;
    height: 24px;
  }
  .footer__social:hover {
    color: var(--accent-2);
    transform: translateY(-3px);
  }
  .footer__title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer__col a,
  .footer__col li {
    color: var(--text-muted);
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }
  .footer__col a:hover {
    color: var(--accent-2);
  }
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--text-dim);
    font-size: 0.85rem;
    padding-top: 1.5rem;
  }
  .footer__legal {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  .footer__legal a {
    color: var(--text-dim);
    transition: color 0.2s ease;
  }
  .footer__legal a:hover {
    color: var(--accent-2);
  }
  @media (max-width: 800px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  /* Móvil: footer a una columna y todo centrado */
  @media (max-width: 640px) {
    .footer__top {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer__brand {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .footer__tagline {
      max-width: 40ch;
      margin-inline: auto;
    }
    .footer__socials {
      justify-content: center;
    }
    .footer__col ul {
      align-items: center;
    }
    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
    .footer__legal {
      justify-content: center;
    }
  }
</style>
