---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- Cierre: sin caja. Un halo naranja suave detrás del titular (etéreo). -->
<section class="cta-final">
  <div class="cta-final__glow" aria-hidden="true"></div>
  <div class="container cta-final__inner" data-reveal>
    <h2 class="cta-final__title">{t('cta.final.title')}</h2>
    <p class="cta-final__sub">{t('cta.final.subtitle')}</p>
    <a href={localizedPath(lang, 'contacto')} class="btn btn-primary btn-lg cta-final__btn">
      {t('cta.final.button')}
      <Icon name="rocket" />
    </a>
  </div>
</section>

<style>
  .cta-final {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    text-align: center;
    padding-block: clamp(4.5rem, 11vw, 9rem);
  }
  /* Halo cálido difuminado, sin bordes: el texto "flota" en él */
  .cta-final__glow {
    position: absolute;
    z-index: -1;
    top: 46%;
    left: 50%;
    width: min(820px, 92vw);
    height: 560px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse 58% 58% at center,
      rgba(251, 84, 18, 0.3),
      rgba(255, 138, 76, 0.12) 45%,
      transparent 72%
    );
    filter: blur(46px);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cta-final__glow {
      animation: cta-pulse 9s ease-in-out infinite alternate;
    }
  }
  @keyframes cta-pulse {
    0% { opacity: 0.65; transform: translate(-50%, -50%) scale(0.94); }
    100% { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
  }

  .cta-final__inner {
    position: relative;
    max-width: 720px;
  }
  .cta-final__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.1rem, 5.2vw, 3.6rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    max-width: 18ch;
    margin-inline: auto;
  }
  .cta-final__sub {
    color: var(--text-muted);
    max-width: 50ch;
    margin: 1.1rem auto 2.3rem;
    font-size: clamp(1rem, 1.6vw, 1.18rem);
  }
  .cta-final__btn {
    box-shadow: 0 16px 44px -14px var(--accent-glow);
  }
</style>
