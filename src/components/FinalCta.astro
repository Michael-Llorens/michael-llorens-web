---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section cta-final">
  <div class="container">
    <div class="cta-final__box" data-reveal>
      <div class="cta-final__glow" aria-hidden="true"></div>
      <h2 class="cta-final__title">{t('cta.final.title')}</h2>
      <p class="cta-final__sub">{t('cta.final.subtitle')}</p>
      <a href={localizedPath(lang, 'contacto')} class="btn btn-primary btn-lg">
        {t('cta.final.button')}
        <Icon name="rocket" />
      </a>
    </div>
  </div>
</section>

<style>
  .cta-final__box {
    position: relative;
    text-align: center;
    padding: clamp(3rem, 7vw, 5rem) clamp(1.5rem, 5vw, 4rem);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--surface-2) 0%, var(--bg-soft) 100%);
    border: 1px solid var(--card-border);
    overflow: hidden;
  }
  .cta-final__glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 60rem;
    height: 40rem;
    background: radial-gradient(circle, rgba(251, 84, 18, 0.22), transparent 60%);
    pointer-events: none;
  }
  .cta-final__title {
    position: relative;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    max-width: 18ch;
    margin-inline: auto;
  }
  .cta-final__sub {
    position: relative;
    color: var(--text-muted);
    max-width: 50ch;
    margin: 1rem auto 2rem;
    font-size: 1.05rem;
  }
</style>
