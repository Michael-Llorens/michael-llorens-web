---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getBackend } from '../data/content';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const items = getBackend(lang);
---

<section class="section backend" id="backend">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('backend.kicker')}</span>
      <h2 class="section-title">{t('backend.title')}</h2>
      <p class="lead">{t('backend.subtitle')}</p>
    </div>

    <div class="backend__grid">
      <!-- Visual: terminal / API -->
      <div class="terminal" data-reveal aria-hidden="true">
        <div class="terminal__bar">
          <span></span><span></span><span></span>
          <em>api · el-buey-madurado</em>
        </div>
        <pre class="terminal__body"><code><span class="c-prompt">$</span> <span class="c-cmd">POST</span> <span class="c-path">/api/pedidos</span>
<span class="c-punct">{`{`}</span>
  <span class="c-key">"mesa"</span><span class="c-punct">:</span> <span class="c-num">12</span><span class="c-punct">,</span>
  <span class="c-key">"items"</span><span class="c-punct">:</span> <span class="c-punct">[</span><span class="c-str">"chuletón"</span><span class="c-punct">,</span> <span class="c-str">"vino"</span><span class="c-punct">]</span>
<span class="c-punct">{`}`}</span>

<span class="c-ok">201 Created</span>  <span class="c-comment">✓ 38 ms</span>
<span class="c-punct">{`{`}</span>
  <span class="c-key">"estado"</span><span class="c-punct">:</span> <span class="c-str">"confirmado"</span><span class="c-punct">,</span>
  <span class="c-key">"tiempo"</span><span class="c-punct">:</span> <span class="c-str">"20 min"</span>
<span class="c-punct">{`}`}</span><span class="cursor">▋</span></code></pre>
      </div>

      <!-- Capacidades -->
      <div class="backend__caps">
        <ul class="caps">
          {
            items.map((c, i) => (
              <li class="cap" data-reveal style={`--reveal-delay:${i * 80}ms`}>
                <span class="cap__ic"><Icon name={c.icon} /></span>
                <div>
                  <h3 class="cap__title">{c.title}</h3>
                  <p class="cap__desc">{c.description}</p>
                </div>
              </li>
            ))
          }
        </ul>

        <p class="backend__proof" data-reveal>
          <Icon name="check" />
          {t('backend.proof')}
        </p>

        <a href={localizedPath(lang, 'contacto')} class="btn btn-primary backend__cta" data-reveal>
          {t('backend.cta')}
          <Icon name="arrow" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .backend__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }

  /* Terminal */
  .terminal {
    border-radius: var(--radius);
    background: #0c0c16;
    border: 1px solid var(--border-strong);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.7rem 0.9rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid var(--border);
  }
  .terminal__bar span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
  }
  .terminal__bar span:nth-child(1) { background: #ff5f57; }
  .terminal__bar span:nth-child(2) { background: #febc2e; }
  .terminal__bar span:nth-child(3) { background: #28c840; }
  .terminal__bar em {
    margin-left: auto;
    font-style: normal;
    font-size: 0.78rem;
    color: var(--text-dim);
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
  }
  .terminal__body {
    margin: 0;
    padding: 1.3rem 1.4rem;
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: clamp(0.78rem, 1.4vw, 0.92rem);
    line-height: 1.7;
    color: #d6d6e6;
    overflow-x: auto;
  }
  .c-prompt { color: var(--accent-2); }
  .c-cmd { color: #ff7b9c; font-weight: 700; }
  .c-path { color: #c0a7ff; }
  .c-key { color: #7cc7ff; }
  .c-str { color: #6ee7a8; }
  .c-num { color: #ffcb6b; }
  .c-punct { color: #8a8aa3; }
  .c-ok { color: #28c840; font-weight: 700; }
  .c-comment { color: var(--text-dim); }
  .cursor {
    color: var(--accent-2);
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  /* Capacidades */
  .caps {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .cap {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .cap__ic {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 13px;
    background: var(--accent-soft);
    border: 1px solid var(--border-strong);
    color: var(--accent-2);
  }
  .cap__ic :global(svg) {
    width: 22px;
    height: 22px;
  }
  .cap__title {
    font-size: 1.12rem;
    margin-bottom: 0.2rem;
  }
  .cap__desc {
    color: var(--text-muted);
    font-size: 0.93rem;
  }
  .backend__proof {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 1.6rem;
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.9rem;
  }
  .backend__proof :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--accent-2);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .backend__cta {
    margin-top: 1.6rem;
  }

  @media (max-width: 860px) {
    .backend__grid {
      grid-template-columns: 1fr;
    }
    .terminal {
      order: 2;
    }
  }
</style>
