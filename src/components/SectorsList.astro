---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getSectors } from '../data/sectors';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const sectors = getSectors(lang);
---

<section class="section sectors" id="sectores" aria-labelledby="sectors-title">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('sectors.kicker')}</span>
      <h2 class="section-title" id="sectors-title">{t('sectors.title')}</h2>
      <p class="lead">{t('sectors.subtitle')}</p>
    </div>

    <div class="grid grid-2">
      {
        sectors.map((s, i) => (
          <a
            href={localizedPath(lang, `sectores/${s.slug}`)}
            class="card card-glow sector"
            data-reveal
            style={`--reveal-delay:${i * 80}ms`}
          >
            <span class="sector__icon">
              <Icon name={s.icon} />
            </span>
            <div>
              <h3 class="sector__name">{s.name}</h3>
              <p class="sector__tagline">{s.tagline}</p>
            </div>
            <Icon name="arrowUpRight" class="sector__arrow" />
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .sector {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    text-decoration: none;
    color: inherit;
  }
  .sector__icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--accent-soft);
    color: var(--accent-2);
  }
  .sector__icon :global(svg) {
    width: 24px;
    height: 24px;
  }
  .sector__name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text);
  }
  .sector__tagline {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.5;
    margin-top: 0.2rem;
  }
  .sector :global(.sector__arrow) {
    width: 1.2rem;
    height: 1.2rem;
    margin-left: auto;
    flex-shrink: 0;
    color: var(--text-dim);
    transition: color 0.25s, transform 0.25s var(--ease);
  }
  .sector:hover :global(.sector__arrow) {
    color: var(--accent-2);
    transform: translate(3px, -3px);
  }
</style>
