---
import { type Lang, localizedPath } from '../i18n/config';
import { useTranslations } from '../i18n/ui';
import { getBlogPosts } from '../data/blog';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = getBlogPosts(lang);
---

<section class="section blog" aria-labelledby="blog-title">
  <div class="container">
    <div class="section-head center" data-reveal>
      <span class="kicker">{t('blog.kicker')}</span>
      <h1 class="section-title" id="blog-title">{t('blog.title')}</h1>
      <p class="lead">{t('blog.subtitle')}</p>
    </div>

    <div class="grid grid-3">
      {
        posts.map((post, i) => (
          <a
            href={localizedPath(lang, `recursos/${post.slug}`)}
            class="card card-glow post"
            data-reveal
            style={`--reveal-delay:${i * 80}ms`}
          >
            <div class="post__meta">
              <span class="post__cat">{post.category}</span>
              <span class="post__time">{post.readingMin} {t('blog.readingMin')}</span>
            </div>
            <h2 class="post__title">{post.title}</h2>
            <p class="post__excerpt">{post.excerpt}</p>
            <span class="post__more">
              {t('hero.cta.secondary')}
              <Icon name="arrowUpRight" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .post {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    text-decoration: none;
    color: inherit;
  }
  .post__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.8rem;
  }
  .post__cat {
    color: var(--accent-2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .post__time {
    color: var(--text-dim);
  }
  .post__title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.3;
    color: var(--text);
  }
  .post__excerpt {
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.6;
    flex: 1;
  }
  .post__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent-2);
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: 0.3rem;
    transition: gap 0.25s var(--ease);
  }
  .post__more :global(svg) {
    width: 1rem;
    height: 1rem;
  }
  .post:hover .post__more {
    gap: 0.7rem;
  }
</style>
