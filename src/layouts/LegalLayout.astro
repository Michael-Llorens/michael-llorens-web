---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '../styles/global.css';
import { site } from '../data/site';
import { useTranslations } from '../i18n/ui';
import { localizedPath } from '../i18n/config';
import Footer from '../components/Footer.astro';
import Icon from './../components/Icon.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
}
const { title, description, slug } = Astro.props;
const t = useTranslations('es');
const canonical = new URL(`/${slug}`, site.url).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        try {
          var th = localStorage.getItem('theme');
          if (th !== 'light' && th !== 'dark') {
            th = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          }
          document.documentElement.setAttribute('data-theme', th);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <title>{title} · {site.name}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0a12" />
  </head>
  <body>
    <header class="legal-bar">
      <div class="container legal-bar__inner">
        <a href={localizedPath('es')} class="brand" aria-label={`${site.name} — inicio`}>
          <span class="brand__logo" aria-hidden="true"></span>
          <span>MetaLogic</span>
        </a>
        <div class="legal-bar__actions">
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Cambiar tema claro/oscuro">
            <Icon name="sun" class="theme-toggle__sun" />
            <Icon name="moon" class="theme-toggle__moon" />
          </button>
          <a href={localizedPath('es')} class="btn btn-ghost legal-bar__home">
            <Icon name="arrow" />
            {t('legal.back')}
          </a>
        </div>
      </div>
    </header>

    <main class="legal">
      <div class="container legal__inner">
        <h1 class="legal__title">{title}</h1>
        <article class="legal__content">
          <slot />
        </article>
      </div>
    </main>

    <Footer lang="es" />

    <script>
      const tgl = document.getElementById('theme-toggle');
      tgl?.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try {
          localStorage.setItem('theme', next);
        } catch (e) {}
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', next === 'light' ? '#ffffff' : '#0a0a12');
      });
    </script>

    <style>
      .legal-bar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--header-bg);
        backdrop-filter: blur(14px) saturate(140%);
        border-bottom: 1px solid var(--border);
      }
      .legal-bar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 70px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        font-family: var(--font-display);
        font-weight: 700;
      }
      .brand__logo {
        width: 51px;
        height: 36px;
        flex-shrink: 0;
        background-image: url('/logo-mark.png');
        background-repeat: no-repeat;
        background-size: contain;
        background-position: center;
      }
      .legal-bar__actions {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }
      .theme-toggle {
        display: grid;
        place-items: center;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text-muted);
        flex-shrink: 0;
      }
      .theme-toggle :global(svg) {
        width: 18px;
        height: 18px;
      }
      .legal-bar__home :global(svg) {
        width: 1.05rem;
        height: 1.05rem;
        transform: rotate(180deg);
      }

      .legal {
        padding-block: clamp(2.5rem, 6vw, 4.5rem);
      }
      .legal__inner {
        max-width: 820px;
      }
      .legal__title {
        font-size: clamp(2rem, 5vw, 3rem);
        margin-bottom: 2rem;
      }
      .legal__content :global(h2) {
        font-size: 1.4rem;
        margin: 2.2rem 0 0.8rem;
      }
      .legal__content :global(h3) {
        font-size: 1.1rem;
        margin: 1.5rem 0 0.5rem;
      }
      .legal__content :global(p),
      .legal__content :global(li) {
        color: var(--text-muted);
        line-height: 1.75;
        margin-bottom: 0.8rem;
      }
      .legal__content :global(ul) {
        list-style: disc;
        padding-left: 1.4rem;
        margin-bottom: 1rem;
      }
      .legal__content :global(a) {
        color: var(--accent-2);
        text-decoration: underline;
      }
      .legal__content :global(strong) {
        color: var(--text);
      }
      .legal__content :global(.legal-updated) {
        font-size: 0.85rem;
        color: var(--text-dim);
        margin-bottom: 2rem;
      }
      @media (max-width: 560px) {
        .legal-bar__home {
          display: none;
        }
      }
    </style>
  </body>
</html>
